{
  "pluginName": "小游戏集合",
  "description": "精选6款小游戏合集，支持云存档功能，包括俄罗斯方块、六边形俄罗斯方块、小黑屋、糖果盒子2、人生重开模拟器、深空迷梦等多款经典游戏。支持存档自动保存和多设备同步。",
  "main": "index.html",
  "logo": "logo.png",
  "version": "2.2.0",
  "author": "575568329",
  "homepage": "https://github.com/575568329/candybox2",
  "development": {
    "main": "http://localhost:5173/#/"
  },
  "features": [
    {
      "code": "games",
      "explain": "小游戏集合 - 选择游戏开始冒险",
      "cmds": [
